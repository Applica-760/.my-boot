{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(which:*)",
      "Bash(date)",
      "Bash(whoami)",
      "Bash(uname:*)",
      "Bash(ps:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git branch -r)",
      "Bash(git branch -v:*)",
      "Bash(git branch --list:*)",
      "Bash(git branch --show-current)",
      "Bash(git branch --contains:*)",
      "Bash(git branch --merged:*)",
      "Bash(git branch --no-merged:*)",
      "Bash(git ls-files:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [{
          "type": "command",
          "command": "osascript -e 'display notification \"タスク完了\" with title \"Claude Code\"'"
        }]
      }
    ]
  }
}